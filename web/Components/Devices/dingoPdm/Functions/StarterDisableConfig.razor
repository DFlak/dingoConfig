@using domain.Devices.dingoPdm.Functions
@using domain.Models
@using web.Services
@inject IDialogService DialogService
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable

<MudCard Outlined="true" Class="mb-2">
    <MudCardContent>
        <MudGrid Spacing="5">
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Enable</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="StarterDisable.Name"
                                      Label="Name"
                                      Variant="Variant.Outlined"/>
                        <MudSwitch @bind-Value="StarterDisable.Enabled"
                                   Label="Enabled"
                                   Color="Color.Primary"/>
                        <MudStack Row="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="(!StarterDisable.Enabled)"
                                           Style="max-width: 20px"
                                           OnClick="@(() => OpenVariableSelectorAsync(StarterDisable, "bool"))">
                            </MudIconButton>
                            <MudText>@GetSelectedVarText(StarterDisable.Input)</MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Disable</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (var i = 0; i < StarterDisable.OutputsDisabled.Count; i++)
                        {
                            var index = i; // Capture loop variable to avoid closure issues
                            <MudSwitch T="bool"
                                       @bind-Value="@StarterDisable.OutputsDisabled[index]"
                                       Label="@($"Output {index + 1}")"
                                       Disabled="!StarterDisable.Enabled"
                                       Color="Color.Primary"/>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public StarterDisable StarterDisable { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    private async Task OpenVariableSelectorAsync(StarterDisable disable, string datatype)
    {
        var parameters = new DialogParameters<VarMapSelectionDialog>
        {
            { x => x.Device, Device},
            { x => x.Datatype, datatype}
        };
        
        var dialog = await DialogService.ShowAsync<VarMapSelectionDialog>("Select Variable", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: (DeviceVariable variable) })
            disable.Input = variable;
    }
    
    private string GetSelectedVarText(DeviceVariable variable)
    {
        if(variable.FunctionName.Length == 0)
            return "Select Variable";

        if (variable.SingleVariable)
            return $"{variable.FunctionName}.{variable.PropertyName}";

        return $"{variable.FunctionName}{variable.FunctionIndex}.{variable.PropertyName}";
    }
}
