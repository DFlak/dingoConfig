@using web.Services
@using domain.Devices.dingoPdm.Functions
@using domain.Devices.dingoPdm.Enums
@using domain.Models
@inject IDialogService DialogService
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable

<MudDataGrid Items="@Flashers" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true" 
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px" />
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Value" Title="Value" Editable="false" CellStyle="max-width: 100px">
            <CellTemplate>
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="@(context.Item.Value ? Color.Success : Color.Default)"
                         Size="Size.Small" Style="min-width: 50px;">
                    @(context.Item.Value ? "ON" : "OFF")
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Single" Title="Single Flash" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Single" Dense="true" Disabled="!context.Item.Enabled"/>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Input" Title="Input" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="(!context.Item.Enabled)"
                                   Style="max-width: 20px"
                                   OnClick="@(() => OpenVariableSelectorAsync(context.Item, "bool"))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.Input)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="On Time (s)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"onTime-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.OnTime"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnTimeChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Off Time (s)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"offTime-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.OffTime"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OffTimeChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public List<Flasher> Flashers { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    private int _refreshCounter;

    private async Task OpenVariableSelectorAsync(Flasher flasher, string datatype)
    {
        var parameters = new DialogParameters<VarMapSelectionDialog>
        {
            { x => x.Device, Device},
            { x => x.Datatype, datatype}
        };
        
        var dialog = await DialogService.ShowAsync<VarMapSelectionDialog>("Select Variable", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: (DeviceVariable variable) })
            flasher.Input = variable;
    }
    
    private void OnTimeChanged(Flasher item, int value)
    {
        const int min = 0;
        const int max = 25;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.OnTime must be {min} to {max}");
        }
        item.OnTime = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OffTimeChanged(Flasher item, int value)
    {
        const int min = 0;
        const int max = 25;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.OffTime must be {min} to {max}");
        }
        item.OffTime = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
    private string GetSelectedVarText(DeviceVariable variable)
    {
        if(variable.FunctionName.Length == 0)
            return "Select Variable";

        if (variable.SingleVariable)
            return $"{variable.FunctionName}.{variable.PropertyName}";

        return $"{variable.FunctionName}{variable.FunctionIndex}.{variable.PropertyName}";
    }
}
