@using web.Services
@using domain.Devices.dingoPdm.Functions
@using domain.Devices.dingoPdm.Enums
@using domain.Models
@inject IDialogService DialogService
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable

<MudDataGrid Items="@Conditions" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true" 
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Value" Title="Value" Editable="false" CellStyle="max-width: 100px">
            <CellTemplate>
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="@(context.Item.Value > 0 ? Color.Success : Color.Default)"
                         Size="Size.Small" Style="min-width: 50px;">
                    @context.Item.Value
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Input" Title="Variable" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="(!context.Item.Enabled)"
                                   Style="max-width: 20px"
                                   OnClick="@(() => OpenVariableSelectorAsync(context.Item, "bool"))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.Input)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Operator" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="Operator" @bind-Value="context.Item.Operator" Variant="Variant.Outlined" Dense="true"
                           Disabled="!context.Item.Enabled">
                    @foreach (Operator op in Enum.GetValues(typeof(Operator)))
                    {
                        <MudSelectItem T="Operator" Value="@op">@op</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Argument" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"arg-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.Arg"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnArgChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public List<Condition> Conditions { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;

    private int _refreshCounter = 0;

    private async Task OpenVariableSelectorAsync(Condition condition, string datatype)
    {
        var parameters = new DialogParameters<VarMapSelectionDialog>
        {
            { x => x.Device, Device},
            { x => x.Datatype, datatype}
        };
        
        var dialog = await DialogService.ShowAsync<VarMapSelectionDialog>("Select Variable", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: (DeviceVariable variable) })
            condition.Input = variable;
    }
    
    private void OnArgChanged(Condition item, int value)
    {
        const int min = 0;
        const int max = 65536;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.Arg must be {min} to {max}");
        }
        item.Arg = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
    private string GetSelectedVarText(DeviceVariable variable)
    {
        if(variable.FunctionName.Length == 0)
            return "Select Variable";

        if (variable.SingleVariable)
            return $"{variable.FunctionName}.{variable.PropertyName}";

        return $"{variable.FunctionName}{variable.FunctionIndex}.{variable.PropertyName}";
    }
}
