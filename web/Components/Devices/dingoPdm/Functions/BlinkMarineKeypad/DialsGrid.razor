@using domain.Devices.dingoPdm.Functions.Keypad
@using domain.Devices.dingoPdm
@using web.Services
@inject NotificationService Notification
@typeparam TDevice where TDevice : PdmDevice

<MudDataGrid Items="@Dials" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="false"
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Min LED" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"minLed-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MinLed"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMinLedChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Max LED" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"maxLed-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MaxLed"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMaxLedChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="LED Offset" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"ledOffset-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.LedOffset"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnLedOffsetChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Max Count (set by SDO)" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"topPosition-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.TopPosition"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnTopPositionChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public IEnumerable<Dial> Dials { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    private int _refreshCounter;

    private void OnMinLedChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.MinLed must be {min} to {max}");
        if (value > item.MaxLed)
            Notification.NewWarning($"{item.Name}.MinLed must be less than MaxLed");
        
        item.MinLed = Math.Clamp(value, min, Math.Clamp(value, item.MaxLed, max));
        _refreshCounter++;
    }
    
    private void OnMaxLedChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.MaxLed must be {min} to {max}");
        if (value < item.MinLed)
            Notification.NewWarning($"{item.Name}.MaxLed must be greater than MinLed");
        
        item.MaxLed = Math.Clamp(value, Math.Clamp(value, min, item.MinLed), max);
        _refreshCounter++;
    }
    
    private void OnLedOffsetChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.LedOffset must be {min} to {max}");
        
        item.LedOffset = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnTopPositionChanged(Dial item, int value)
    {
        const int min = 2;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.LedOffset must be {min} to {max}");
        
        item.LedOffset = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
}