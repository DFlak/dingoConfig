@using domain.Devices.dingoPdm.Functions.Keypad
@using domain.Devices.Keypad.BlinkMarine.Enums
@using web.Services
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Devices.dingoPdm.PdmDevice
@inherits PdmFunctionComponentBase<TDevice>

<MudGrid Spacing="2">
    <MudItem>
        <MudCard Elevation="4">
            <MudCardHeader>Backlight</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudSelect T="BacklightColor" Value="_backlightColor" Style="max-width: 200px" Label="Color"
                               Variant="Variant.Outlined" Dense="true"
                               ValueChanged="BacklightColorChanged">
                        @foreach (BacklightColor backlight in Enum.GetValues(typeof(BacklightColor)))
                        {
                            <MudSelectItem T="BacklightColor" Value="@backlight">@backlight</MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField Value="Keypad.BacklightBrightness"
                                     Label="Brightness (0-63)"
                                     Style="max-width: 200px"
                                     ValueChanged="@((int val) => OnBacklightBrightnessChanged(val))"/>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem>
        <MudCard Elevation="4">
            <MudCardHeader>Dim Backlight</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudNumericField Value="Keypad.DimBacklightBrightness"
                                     Label="Brightness (0-63)"
                                     ValueChanged="@((int val) => OnDimBacklightBrightnessChanged(val))"/>

                    <MudStack Row="false">
                        <MudText>Dimming Var</MudText>
                        <MudStack Row="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="(!Keypad.Enabled)"
                                           Style="max-width: 20px"
                                           OnClick="@(() => OpenVariableSelectorAsync("bool", v => Keypad.DimmingVar = v))">
                            </MudIconButton>
                            <MudText>@GetSelectedVarText(Keypad.DimmingVar)</MudText>

                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public KeypadMaster Keypad { get; set; } = null!;

    private BacklightColor _backlightColor = BacklightColor.Amber;
    
    private void OnBacklightBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.BacklightBrightness must be {min} to {max}");
        }
        Keypad.BacklightBrightness = Math.Clamp(value, min, max);
    }

    private void OnDimBacklightBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.DimBacklightBrightness must be {min} to {max}");
        }
        Keypad.DimBacklightBrightness = Math.Clamp(value, min, max);
    }

    private void BacklightColorChanged(BacklightColor color)
    {
        _backlightColor = color;

        Keypad.BacklightColor = (int)color;
    }

}