@using domain.Devices.dingoPdm.Functions.Keypad
@using domain.Devices.dingoPdm
@using domain.Models
@using domain.Devices.Keypad.BlinkMarine.Enums
@inject IDialogService DialogService
@typeparam TDevice where TDevice : PdmDevice

<MudDataGrid Items="@Buttons" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="false"
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        
        @for (var i = 0; i < 4; i++)
        {
            var index = i;
            var title = $"Color {index}"; 
            <TemplateColumn Title=@title Resizable="true" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="ButtonColor" Value="@_colors[index]" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" 
                               ValueChanged="@((ButtonColor val) => OnColorChanged(context.Item.Colors[index], val))">
                        @foreach (ButtonColor color in Enum.GetValues(typeof(ButtonColor)))
                        {
                            <MudSelectItem T="ButtonColor" Value="@color">@color</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </TemplateColumn>

            title = $"Blink Color {index}";
            <TemplateColumn Title=@title Resizable="true" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="ButtonColor" Value="@_blinkColors[index]" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" 
                               ValueChanged="@((ButtonColor val) => OnColorChanged(context.Item.BlinkColors[index], val))">
                        @foreach (ButtonColor color in Enum.GetValues(typeof(ButtonColor)))
                        {
                            <MudSelectItem T="ButtonColor" Value="@color">@color</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </TemplateColumn>
        }
        <TemplateColumn Title="Fault Color" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="ButtonColor" Value="@_faultColor" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" 
                           ValueChanged="@((ButtonColor val) => OnColorChanged(context.Item.FaultColor, val))">
                    @foreach (ButtonColor color in Enum.GetValues(typeof(ButtonColor)))
                    {
                        <MudSelectItem T="ButtonColor" Value="@color">@color</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Fault Blink" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="ButtonColor" Value="@_faultBlinkColor" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" 
                           ValueChanged="@((ButtonColor val) => OnColorChanged(context.Item.FaultBlinkColor, val))">
                    @foreach (ButtonColor color in Enum.GetValues(typeof(ButtonColor)))
                    {
                        <MudSelectItem T="ButtonColor" Value="@color">@color</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public IEnumerable<Button> Buttons { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    ButtonColor[] _colors = new ButtonColor[4];
    ButtonColor[] _blinkColors = new ButtonColor[4];
    ButtonColor _faultColor;
    ButtonColor _faultBlinkColor;

    private void OnColorChanged(int item, ButtonColor val)
    {
        item = (int)val;
    }

}