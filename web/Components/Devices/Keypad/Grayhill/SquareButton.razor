@using domain.Devices.Keypad.Enums
@using domain.Devices.Keypad.Grayhill.Functions
@using MudBlazor

<MudStack Spacing="1" AlignItems="AlignItems.Center" Style="display: inline-flex;">
    <div class="square-button-container @(Button.State ? "pressed" : "")"
         style="width: @(Size)px; height: @(Size)px; cursor: @(Enabled ? "pointer" : "not-allowed");"
         @onmousedown="HandleButtonDown"
         @ontouchstart="HandleButtonDown"
         @onmouseup="HandleButtonUp"
         @onmouseleave="HandleButtonUp"
         @ontouchend="HandleButtonUp">
        <div class="led-row">
            @for (var i = 0; i < Button.Led.Length; i++)
            {
                var index = i;
                <div class="square-led @(Button.Led[index] ? "led-on" : "")"></div>
            }
        </div>
        <div class="square-button-icon">
            <MudIcon Icon="@Button.Icon" Style="@($"color: white; font-size: {Size * 0.5}px;")" />
        </div>
    </div>

    <MudText Align="Align.Center" Style="@($"width: {Size}px;")">@Button.Name</MudText>
</MudStack>

@code {
    [Parameter]
    public int Size { get; set; } = 100;

    [Parameter, EditorRequired]
    public Button Button { get; set; } = null!;

    [Parameter, EditorRequired]
    public bool Enabled { get; set; }

    private void HandleButtonDown()
    {
        if (!Enabled) return;
        Button.State = Button.Mode switch
        {
            ButtonMode.Momentary => true,
            ButtonMode.Latching => !Button.State,
            _ => Button.State
        };
    }
    
    private void HandleButtonUp()
    {
        if (!Enabled) return;
        Button.State = Button.Mode switch
        {
            ButtonMode.Momentary => false,
            _ => Button.State
        };
    }
}

<style>
    .square-button-container {
        border-radius: 6px;
        background-color: #1a1a1a;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 8px;
        gap: 4px;
        margin: 4px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.4);
        transition: transform 0.1s ease, box-shadow 0.1s ease;
    }

    .square-button-container.pressed {
        transform: scale(0.9);
        box-shadow: 0 0 0 3px var(--mud-palette-primary), 0 1px 2px rgba(0, 0, 0, 0.3);
    }

    .led-row {
        display: flex;
        flex-direction: row;
        gap: 4px;
        align-items: center;
        justify-content: center;
        width: 100%;
    }

    .square-led {
        width: 8px;
        height: 8px;
        border-radius: 2px;
        background-color: #333;
        transition: background-color 0.15s ease;
    }

    .square-led.led-on {
        background-color: orange;
        box-shadow: 0 0 5px orange;
    }

    .square-button-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        width: 100%;
    }
</style>
