@using domain.Interfaces
@using domain.Devices.Keypad.BlinkMarine
@using domain.Devices.Keypad.Grayhill
@using api.Components.Devices.Keypad.Tabs

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
    <MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
        @switch (Device)
        {
            case BlinkMarineKeypadDevice blinkKeypad:
                <api.Components.Devices.Keypad.BlinkMarine.Tabs.DashboardTab Device="blinkKeypad" />
                break;

            case GrayhillKeypadDevice grayhillKeypad:
                <api.Components.Devices.Keypad.Grayhill.Tabs.DashboardTab Device="grayhillKeypad" />
                break;
        }
    </MudTabPanel>
    
    <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
        @switch (Device)
        {
            case BlinkMarineKeypadDevice blinkKeypad:
                <api.Components.Devices.Keypad.BlinkMarine.Tabs.SettingsTab Device="blinkKeypad" />
                break;

            case GrayhillKeypadDevice grayhillKeypad:
                <api.Components.Devices.Keypad.Grayhill.Tabs.SettingsTab Device="grayhillKeypad" />
                break;
        }
    </MudTabPanel>
    
    <MudTabPanel Text="SDO" Icon="@Icons.Material.Filled.SyncAlt">
        <SdoDashboard Device="Device" />
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter] public IDevice Device { get; set; } = default!;
}
