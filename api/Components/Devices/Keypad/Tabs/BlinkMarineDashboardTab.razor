@using domain.Devices.Keypad.BlinkMarine
@using domain.Devices.Keypad.BlinkMarine.Enums

<MudGrid>
    @foreach (var button in Device.Buttons)
    {
        <MudItem>
            <RingButton Button="@button" Size="80"/>
        </MudItem>
    }
    <MudItem xs="12">
        <MudText Typo="Typo.h6">Buttons</MudText>
        <MudTable Items="@Device.Buttons" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Number</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>State</MudTh>
                <MudTh>Indicator</MudTh>
                <MudTh>Blink</MudTh>
                <MudTh>Backlight</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Number</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudChip T="string" Color="@(context.State ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.State ? "Pressed" : "Released")
                    </MudChip>
                </MudTd>
                <MudTd>@context.IndicatorColor</MudTd>
                <MudTd>@context.BlinkColor</MudTd>
                <MudTd>@context.BacklightColor</MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>

    @if (Device.NumDials > 0)
    {
        <MudItem xs="12" Class="mt-4">
            <MudText Typo="Typo.h6">Dials</MudText>
            <MudTable Items="@Device.Dials" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Number</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Position</MudTh>
                    <MudTh>Delta</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Number</MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.Position</MudTd>
                    <MudTd>@context.Delta</MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    }

    @if (Device.NumAnalogInputs > 0)
    {
        <MudItem xs="12" Class="mt-4">
            <MudText Typo="Typo.h6">Analog Inputs</MudText>
            <MudTable Items="@Device.AnalogInputs" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Number</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Voltage (mV)</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Number</MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.Voltage.ToString("F2")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] public BlinkMarineKeypadDevice Device { get; set; } = default!;
}
